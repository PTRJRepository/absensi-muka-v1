APP_ENV=development
APP_PORT=3000

DB_SERVER=localhost
DB_PORT=1433
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=rebinmas_absensi_monitoring
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

JWT_SECRET=change_me
JWT_EXPIRES_IN=1d

SYNC_INTERVAL_MINUTES=15

ZKTECO_PASSWORD=change_me_machine_password
ZKTECO_TIMEOUT_MS=30000

# Static API key for external data-pull integrations (never expires).
# Send as header: X-API-Key: <value>. Grants SUPER_ADMIN read access.
ATTENDANCE_API_KEY=generate_with_node_e_crypto_randomBytes
