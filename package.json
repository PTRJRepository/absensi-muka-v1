{
  "name": "absensi-muka",
  "version": "1.0.0",
  "description": "Monitoring Absensi Muka PT Rebinmas Jaya",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "seed:dummy": "ts-node src/seed/seed-dummy.ts",
    "db:check": "ts-node src/scripts/check-db.ts",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "seed:machines": "ts-node src/seed/seed-machine-inventory.ts",
    "sync:machines": "ts-node src/scripts/sync-machines.ts",
    "db:migrate": "ts-node src/scripts/run-migrations.ts",
    "recovery": "ts-node src/scripts/run-emergency-recovery.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^12.5.5",
    "node-cron": "^4.4.1",
    "node-zklib": "1.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mssql": "^12.3.0",
    "@types/node": "22.15.21",
    "@types/node-cron": "^3.0.11",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "vitest": "^4.1.9"
  }
}
